# Copy this file to .env and set your values.
# Used by docker-compose.yml for auto-commit container push auth.

# Preferred mode: SSH deploy key mounted into container.
USE_SSH_AUTH=true
SSH_PRIVATE_KEY_PATH=/ABSOLUTE/PATH/TO/PRIVATE_KEY
SSH_KNOWN_HOSTS_PATH=/ABSOLUTE/PATH/TO/known_hosts

# Optional fallback mode: token-based auth (leave blank when using SSH auth).
GITHUB_TOKEN=

PROTECTED_BRANCHES=main master